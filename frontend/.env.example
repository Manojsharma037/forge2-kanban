# Base URL of the Laravel API, including the /api prefix.
# Vite inlines this at BUILD TIME, so set it before building/deploying.
#
# Local development (default if unset):
#   VITE_API_URL=http://127.0.0.1:8000/api
#
# Production (your deployed Render service):
#   VITE_API_URL=https://forge-kanban-api.onrender.com/api

VITE_API_URL=http://127.0.0.1:8000/api
